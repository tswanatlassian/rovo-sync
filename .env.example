# Rovo Sync Configuration
# Copy this to .env and fill in your values

# Jira Configuration
JIRA_URL=https://timswn-aibw.atlassian.net
JIRA_TOKEN=your_jira_api_token_here

# Confluence Configuration
CONFLUENCE_URL=https://timswn-aibw.atlassian.net/wiki
CONFLUENCE_TOKEN=your_confluence_api_token_here

# Planning Pages to Monitor
# Format: {"page_id": "space_key", ...}
PLANNING_PAGES={"3670017": "TACS"}

# Webhook Secret (for verifying webhook requests)
WEBHOOK_SECRET=your_random_secret_here

# Logging
LOG_LEVEL=INFO

# Optional: Slack Notifications
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Webhook Server (if running locally)
PORT=5000
